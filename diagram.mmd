flowchart TD
    classDef system fill:#636e72,stroke:#b2bec3,stroke-width:2px,color:#fff;
    classDef anchor fill:#2d3436,stroke:#dfe6e9,stroke-width:2px,color:#fff;
    classDef branch fill:#0984e3,stroke:#74b9ff,stroke-width:2px,color:#fff;
    classDef leaf fill:#fdcb6e,stroke:#ffeaa7,stroke-width:2px,color:#2d3436;
    classDef tag fill:#e84393,stroke:#fd79a8,stroke-width:2px,color:#fff;

    subgraph SYS [System Ecosystem]
        USER((user)):::system
        GROUPS((groups)):::system
    end

    subgraph L0 [Level 0: Independent Anchors]
        CATEGORY((category)):::tag
        PRODUCT((product)):::anchor
        EMISSION((emission_factor)):::anchor
        POLICY((esg_policy)):::anchor
        REWARD((reward)):::anchor
        CHALLENGE((challenge)):::anchor
        AUDIT((audit)):::anchor
        CSR((csr_activity)):::anchor
        BADGE((badge)):::anchor
    end

    subgraph L1 [Level 1: Contextual Branches]
        PROFILE[product_esg_profile]:::branch
        GOAL[environmental_goal]:::branch
    end

    subgraph L2 [Level 2: The Universal Ledger Leaf]
        TX[esg_transaction]:::leaf
    end

    %% Level 1 Structural Edges
    PROFILE -- "a_product / a_emission" --> PRODUCT & EMISSION
    GOAL -- "a_group" --> GROUPS
    
    %% The Absolute Graph Engine (Polymorphic Double-Entry)
    TX -- "a_from / a_to" --> USER & GROUPS
    TX -- "a_from / a_to" --> PROFILE & CSR & CHALLENGE & POLICY & REWARD & AUDIT

    %% Universal State Classification
    CATEGORY -. "a_category Classification Engine" .-> TX & PROFILE & GOAL & L0

    %% Frontend Derived Logic (No math connections)
    BADGE -. "Derived in Views" .- USER