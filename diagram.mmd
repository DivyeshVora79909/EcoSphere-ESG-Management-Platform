flowchart TD

%% =====================================================
%% Styles
%% =====================================================

classDef system fill:#636e72,stroke:#b2bec3,stroke-width:2px,color:#fff;
classDef anchor fill:#2d3436,stroke:#dfe6e9,stroke-width:2px,color:#fff;
classDef branch fill:#0984e3,stroke:#74b9ff,stroke-width:2px,color:#fff;
classDef ledger fill:#fdcb6e,stroke:#ffeaa7,stroke-width:2px,color:#2d3436;
classDef taxonomy fill:#e84393,stroke:#fd79a8,stroke-width:2px,color:#fff;

%% =====================================================
%% External Actors
%% =====================================================

subgraph ECOSYSTEM["System Ecosystem"]
    USER((User)):::system
    GROUP((Group)):::system
end

%% =====================================================
%% Level 0
%% =====================================================

subgraph L0["Level 0 • Independent Anchors"]

    PRODUCT((Product)):::anchor
    EMISSION((Emission Factor)):::anchor
    POLICY((ESG Policy)):::anchor
    REWARD((Reward)):::anchor
    CHALLENGE((Challenge)):::anchor
    AUDIT((Audit)):::anchor
    CSR((CSR Activity)):::anchor

    CATEGORY((Category)):::taxonomy
end

%% =====================================================
%% Level 1
%% =====================================================

subgraph L1["Level 1 • Contextual Branches"]

    PROFILE["Product ESG Profile"]:::branch
    GOAL["Environmental Goal"]:::branch

end

%% =====================================================
%% Level 2
%% =====================================================

subgraph L2["Level 2 • Universal ESG Ledger"]

    TX["ESG Transaction"]:::ledger

end

%% =====================================================
%% Structural Relationships
%% =====================================================

PROFILE -->|a_product| PRODUCT
PROFILE -->|a_emission| EMISSION

GOAL -->|a_group| GROUP

%% =====================================================
%% Universal Ledger Connections
%% =====================================================

TX -->|a_from / a_to| USER
TX -->|a_from / a_to| GROUP

TX -->|a_from / a_to| PROFILE
TX -->|a_from / a_to| CSR
TX -->|a_from / a_to| POLICY
TX -->|a_from / a_to| CHALLENGE
TX -->|a_from / a_to| REWARD
TX -->|a_from / a_to| AUDIT

%% =====================================================
%% Classification Layer
%% =====================================================

CATEGORY -.-> PRODUCT
CATEGORY -.-> EMISSION
CATEGORY -.-> PROFILE
CATEGORY -.-> GOAL
CATEGORY -.-> POLICY
CATEGORY -.-> REWARD
CATEGORY -.-> CHALLENGE
CATEGORY -.-> CSR
CATEGORY -.-> AUDIT
CATEGORY -.-> TX

%% =====================================================
%% Derived Objects
%% =====================================================

BADGE["Badge (Derived View)"]:::branch

BADGE -.-> USER